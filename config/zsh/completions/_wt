#compdef wt

# wt completions: subcommands, worktree names, branch names.
# Lives on $fpath (prepended in $ZDOTDIR/.zshenv) so compinit registers it
# automatically — survives any number of compinit reruns from later-sourced
# rc files.

if (( CURRENT == 2 )); then
    local -a vals disp
    vals=(cd push pull swap fork add rm sync merge clean prune prune-branches list)
    disp=(
        "cd     -- Jump to a worktree by name or branch (no arg → list)"
        "push   -- Current branch → worktree, main → switch-to"
        "pull   -- Worktree branch → main dir"
        "swap   -- Swap main dir branch ↔ worktree"
        "fork   -- Branch off <ref> into new or existing worktree"
        "add    -- Add <ref> (branch/tag/sha) as a new worktree"
        "rm     -- Remove worktree (auto-purges its bazel cache)"
        "sync   -- Run \`git sync\` in every clean worktree"
        "merge  -- Merge <ref> (branch/tag/sha) into a worktree"
        "clean  -- Discard unstaged + remove untracked (IRREVERSIBLE)"
        "prune  -- Remove bazel output_base dirs for dead worktrees"
        "prune-branches -- fzf-pick local branches to delete (-f forces -D)"
        "list   -- List all worktrees"
    )
    compadd -l -d disp -a vals
    return
fi

case "${words[2]}" in
    pull|rm|remove)
        if (( CURRENT == 3 )); then
            local -a vals disp
            _wt_worktree_compdata --linked
            compadd -l -d disp -a vals
        fi
        ;;
    swap)
        # `wt swap <existing-wt> [--into <new-wt-name>]` — pos 3 is an existing
        # worktree; --into is a new worktree name (freeform, no completion).
        case "${words[CURRENT-1]}" in
            --into)
                _message "name for the new worktree that receives main's old branch"
                return ;;
        esac
        if (( CURRENT == 3 )); then
            local -a vals disp
            _wt_worktree_compdata --linked
            compadd -l -d disp -a vals
        else
            local -a flags fdisp
            flags=(--into)
            fdisp=("--into  -- name for the new worktree holding main's old branch (optional; default derived from branch)")
            compadd -l -d fdisp -a flags
        fi
        ;;
    cd|goto)
        # Jump target: worktrees + the main repo only. (Typing a checked-out
        # branch name still works at runtime, but we don't clutter completion
        # with every local branch — worktrees and driving are the real targets.)
        if (( CURRENT == 3 )); then
            local -a vals disp
            _wt_worktree_compdata
            compadd -l -d disp -a vals
        fi
        ;;
    push)
        # `wt push <wt-name> [--switch-to <branch>]` — pos 3 is the new worktree
        # name (freeform); --switch-to takes a branch.
        case "${words[CURRENT-1]}" in
            --switch-to)
                local -a branches
                branches=(${(@f)"$(git -C "${MAIN_REPO:-$HOME}" branch --format='%(refname:short)' 2>/dev/null)"})
                compadd -a branches
                return ;;
        esac
        if (( CURRENT == 3 )); then
            _message 'new worktree dir name for the current branch'
        else
            local -a flags fdisp
            flags=(--switch-to)
            fdisp=("--switch-to  -- branch the main repo checks out afterward (optional; default master)")
            compadd -l -d fdisp -a flags
        fi
        ;;
    add)
        # `wt add <ref> --into <wt-name> [--remote <remote>]` — pos 3 is the base
        # ref (branches; tags/SHAs typed manually); --into is a new worktree name
        # (freeform); --remote completes configured remotes.
        case "${words[CURRENT-1]}" in
            --into)
                _message 'new worktree dir name (created under ~/worktrees)'
                return ;;
            --remote)
                local -a remotes
                remotes=(${(@f)"$(git -C "${MAIN_REPO:-$HOME}" remote 2>/dev/null)"})
                compadd -a remotes
                return ;;
        esac
        if (( CURRENT == 3 )); then
            local -a branches
            branches=(${(@f)"$(git -C "${MAIN_REPO:-$HOME}" branch -a --format='%(refname:short)' 2>/dev/null | sed -e 's|^origin/||' -e '/^HEAD$/d' | sort -u)"})
            compadd -X '<ref> -- base ref to check out: branch / tag / sha (tags & SHAs typed manually)' -a branches
        else
            local -a flags fdisp
            flags=(--into --remote)
            fdisp=(
                "--into    -- worktree dir name to create (required)"
                "--remote  -- remote to resolve <ref> against (optional; default origin)"
            )
            compadd -l -d fdisp -a flags
        fi
        ;;
    merge)
        # `wt merge --ref <branch> [--into <wt>]` — --ref takes a branch (local +
        # remote), --into an existing worktree.
        case "${words[CURRENT-1]}" in
            --ref)
                local -a branches
                branches=(${(@f)"$(git -C "${MAIN_REPO:-$HOME}" branch -a --format='%(refname:short)' 2>/dev/null | sed -e 's|^origin/||' -e '/^HEAD$/d' | sort -u)"})
                compadd -X '<ref> -- branch / tag / sha to merge in (tags & SHAs typed manually)' -a branches
                return
                ;;
            --into)
                local -a vals disp
                _wt_worktree_compdata
                compadd -l -d disp -a vals
                return
                ;;
        esac
        local -a flags fdisp
        flags=(--ref --into)
        fdisp=(
            "--ref   -- ref to merge in: branch / tag / sha (required)"
            "--into  -- target worktree to merge into (optional; default = cwd's worktree)"
        )
        compadd -l -d fdisp -a flags
        ;;
    clean)
        # `wt clean [--into <wt>] [-x] [-y]` — flags only; --into takes a wt name.
        case "${words[CURRENT-1]}" in
            --into)
                local -a vals disp
                _wt_worktree_compdata
                compadd -l -d disp -a vals
                return
                ;;
        esac
        local -a flags fdisp
        flags=(--into -x -y)
        fdisp=(
            "--into  -- Target a specific worktree"
            "-x      -- Also remove ignored files"
            "-y      -- Skip y/N confirmation"
        )
        compadd -l -d fdisp -a flags
        ;;
    prune)
        # `wt prune [-y] [--sudo]`
        local -a flags fdisp
        flags=(-y --yes --sudo)
        fdisp=(
            "-y      -- Skip y/N confirmation"
            "--yes   -- Skip y/N confirmation"
            "--sudo  -- Prepend sudo to chmod + rm (escape hatch)"
        )
        compadd -l -d fdisp -a flags
        ;;
    fork)
        # `wt fork --from <ref> --name <branch> [--into <wt>]`
        # --from completes worktree names + branch names (tags/SHAs typed).
        # --into completes worktree names. --name takes no completion.
        case "${words[CURRENT-1]}" in
            --from)
                # worktrees (name -- branch) + branch names (tags/SHAs typed manually)
                local -a vals disp branches
                _wt_worktree_compdata
                branches=(${(@f)"$(git -C "${MAIN_REPO:-$HOME}" branch -a --format='%(refname:short)' 2>/dev/null | sed -e 's|^origin/||' -e '/^HEAD$/d' | sort -u)"})
                compadd -l -d disp -a vals
                compadd -a branches
                return
                ;;
            --into)
                local -a vals disp
                _wt_worktree_compdata
                compadd -l -d disp -a vals
                return
                ;;
            --name)
                return
                ;;
        esac
        local -a flags fdisp
        flags=(--from --name --into)
        fdisp=(
            "--from  -- Base ref (worktree name / branch / tag / sha)"
            "--name  -- New branch name"
            "--into  -- Target worktree (existing → in-place, missing → create)"
        )
        compadd -l -d fdisp -a flags
        ;;
    prune-branches)
        # `wt prune-branches [-f]` — branch selection is interactive (fzf);
        # only the force flag is completable.
        if (( CURRENT == 3 )); then
            local -a flags fdisp
            flags=(-f --force -h --help)
            fdisp=(
                "-f      -- Force-delete the selection with -D"
                "--force -- Force-delete the selection with -D"
                "-h      -- Show usage"
                "--help  -- Show usage"
            )
            compadd -l -d fdisp -a flags
        fi
        ;;
esac
